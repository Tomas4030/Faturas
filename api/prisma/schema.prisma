generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReceiptStatus {
  processing
  needs_review
  ready
  failed
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String         @map("password_hash")
  name         String?
  receipts     Receipt[]
  suppliers    Supplier[]
  categoryCorrections CategoryCorrection[]
  subscription Subscription?
  usageCounters UsageCounter[]
  recurringExpenses RecurringExpense[]
  budgets      Budget[]
  activityLogs ActivityLog[]
  kidProfiles  KidProfile[]
  ownedSpaces  Space[]        @relation("OwnedSpaces")
  spaceMemberships SpaceMember[]
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

model Plan {
  id                  String         @id @default(cuid())
  name                String         @unique
  priceCents          Int            @map("price_cents")
  monthlyReceiptLimit Int            @map("monthly_receipt_limit")
  monthlySplitLimit   Int            @map("monthly_split_limit")
  subscriptions       Subscription[]
  createdAt           DateTime       @default(now()) @map("created_at")

  @@map("plans")
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId    String   @map("plan_id")
  plan      Plan     @relation(fields: [planId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model UsageCounter {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")
  receiptsScanned Int      @default(0) @map("receipts_scanned")
  splitsCreated   Int      @default(0) @map("splits_created")

  @@unique([userId, periodStart])
  @@map("usage_counters")
}

model Supplier {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  nif            String?
  normalizedName String    @map("normalized_name")
  category       String?
  receipts       Receipt[]
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([userId, nif])
  @@unique([userId, normalizedName])
  @@map("suppliers")
}

model CategoryCorrection {
  id                     String   @id @default(cuid())
  userId                 String   @map("user_id")
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  normalizedMerchantName String   @map("normalized_merchant_name")
  category               String
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@unique([userId, normalizedMerchantName])
  @@map("category_corrections")
}

model ReceiptTax {
  id          String  @id @default(cuid())
  receiptId   String  @map("receipt_id")
  receipt     Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  rate        Int
  baseCents   Int     @map("base_cents")
  amountCents Int     @map("amount_cents")

  @@map("receipt_taxes")
}

enum SplitSessionStatus {
  open
  closed
}

model SplitSession {
  id          String             @id @default(cuid())
  receiptId   String             @map("receipt_id")
  receipt     Receipt            @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  publicToken String             @unique @map("public_token")
  status      SplitSessionStatus @default(open)
  expiresAt   DateTime           @map("expires_at")
  participants Participant[]
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@map("split_sessions")
}

model Participant {
  id             String                 @id @default(cuid())
  splitSessionId String                 @map("split_session_id")
  splitSession   SplitSession           @relation(fields: [splitSessionId], references: [id], onDelete: Cascade)
  displayName    String                 @map("display_name")
  claims         ParticipantItemClaim[]
  createdAt      DateTime               @default(now()) @map("created_at")

  @@map("participants")
}

model ParticipantItemClaim {
  id              String      @id @default(cuid())
  participantId   String      @map("participant_id")
  participant     Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  receiptItemId   String      @map("receipt_item_id")
  receiptItem     ReceiptItem @relation(fields: [receiptItemId], references: [id], onDelete: Cascade)
  quantityClaimed Decimal     @map("quantity_claimed") @db.Decimal(10, 3)
  createdAt       DateTime    @default(now()) @map("created_at")

  @@unique([participantId, receiptItemId])
  @@map("participant_item_claims")
}

model Receipt {
  id              String        @id @default(cuid())
  userId          String        @map("user_id")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  splitSessions   SplitSession[]
  supplierId      String?       @map("supplier_id")
  supplier        Supplier?     @relation(fields: [supplierId], references: [id])
  category        String?
  taxes           ReceiptTax[]
  merchantName    String?       @map("merchant_name")
  merchantNif     String?       @map("merchant_nif")
  documentNumber  String?       @map("document_number")
  documentDate    DateTime?     @map("document_date") @db.Date
  currency        String        @default("EUR")
  subtotalCents   Int?          @map("subtotal_cents")
  taxCents        Int?          @map("tax_cents")
  discountCents   Int?          @map("discount_cents")
  tipCents        Int?          @map("tip_cents")
  totalCents      Int?          @map("total_cents")
  status          ReceiptStatus @default(processing)
  imageStorageKey String        @map("image_storage_key")
  mimeType        String        @map("mime_type")
  fileSize        Int           @map("file_size")
  rawOcrJson      Json?         @map("raw_ocr_json")
  warnings        Json?
  failureReason   String?       @map("failure_reason")
  items           ReceiptItem[]
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("receipts")
}

model ReceiptItem {
  id             String   @id @default(cuid())
  receiptId      String   @map("receipt_id")
  receipt        Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  description    String
  quantity       Decimal  @db.Decimal(10, 3)
  unitPriceCents Int      @map("unit_price_cents")
  totalCents     Int      @map("total_cents")
  category       String?
  confidence     Float?
  position       Int
  suspect        Boolean  @default(false)
  claims         ParticipantItemClaim[]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("receipt_items")
}


model RecurringExpense {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  description String
  amountCents Int      @map("amount_cents")
  category    String?
  dayOfMonth  Int      @default(1) @map("day_of_month")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("recurring_expenses")
}

model Budget {
  id              String @id @default(cuid())
  userId          String @map("user_id")
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        String
  monthlyLimitCents Int  @map("monthly_limit_cents")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([userId, category])
  @@map("budgets")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
}

model KidProfile {
  id             String    @id @default(cuid())
  parentId       String    @map("parent_id")
  parent         User      @relation(fields: [parentId], references: [id], onDelete: Cascade)
  name           String
  balanceCents   Int       @default(0) @map("balance_cents")
  allowanceCents Int       @default(0) @map("allowance_cents")
  allowanceDay   Int       @default(1) @map("allowance_day")
  tasks          KidTask[]
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("kid_profiles")
}

model KidTask {
  id          String      @id @default(cuid())
  kidId       String      @map("kid_id")
  kid         KidProfile  @relation(fields: [kidId], references: [id], onDelete: Cascade)
  description String
  rewardCents Int         @map("reward_cents")
  completed   Boolean     @default(false)
  completedAt DateTime?   @map("completed_at")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@map("kid_tasks")
}

model Space {
  id        String        @id @default(cuid())
  name      String
  ownerId   String        @map("owner_id")
  owner     User          @relation("OwnedSpaces", fields: [ownerId], references: [id])
  members   SpaceMember[]
  createdAt DateTime      @default(now()) @map("created_at")

  @@map("spaces")
}

model SpaceMember {
  id       String   @id @default(cuid())
  spaceId  String   @map("space_id")
  space    Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId   String   @map("user_id")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String   @default("member")
  joinedAt DateTime @default(now()) @map("joined_at")

  @@unique([spaceId, userId])
  @@map("space_members")
}
