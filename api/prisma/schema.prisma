generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReceiptStatus {
  processing
  needs_review
  ready
  failed
}

model Supplier {
  id             String    @id @default(cuid())
  name           String
  nif            String?   @unique
  normalizedName String    @unique @map("normalized_name")
  category       String?
  receipts       Receipt[]
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("suppliers")
}

model CategoryCorrection {
  id                     String   @id @default(cuid())
  normalizedMerchantName String   @unique @map("normalized_merchant_name")
  category               String
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("category_corrections")
}

model ReceiptTax {
  id          String  @id @default(cuid())
  receiptId   String  @map("receipt_id")
  receipt     Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  rate        Int
  baseCents   Int     @map("base_cents")
  amountCents Int     @map("amount_cents")

  @@map("receipt_taxes")
}

enum SplitSessionStatus {
  open
  closed
}

model SplitSession {
  id          String             @id @default(cuid())
  receiptId   String             @map("receipt_id")
  receipt     Receipt            @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  publicToken String             @unique @map("public_token")
  status      SplitSessionStatus @default(open)
  expiresAt   DateTime           @map("expires_at")
  participants Participant[]
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@map("split_sessions")
}

model Participant {
  id             String                 @id @default(cuid())
  splitSessionId String                 @map("split_session_id")
  splitSession   SplitSession           @relation(fields: [splitSessionId], references: [id], onDelete: Cascade)
  displayName    String                 @map("display_name")
  claims         ParticipantItemClaim[]
  createdAt      DateTime               @default(now()) @map("created_at")

  @@map("participants")
}

model ParticipantItemClaim {
  id              String      @id @default(cuid())
  participantId   String      @map("participant_id")
  participant     Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  receiptItemId   String      @map("receipt_item_id")
  receiptItem     ReceiptItem @relation(fields: [receiptItemId], references: [id], onDelete: Cascade)
  quantityClaimed Decimal     @map("quantity_claimed") @db.Decimal(10, 3)
  createdAt       DateTime    @default(now()) @map("created_at")

  @@unique([participantId, receiptItemId])
  @@map("participant_item_claims")
}

model Receipt {
  id              String        @id @default(cuid())
  splitSessions   SplitSession[]
  supplierId      String?       @map("supplier_id")
  supplier        Supplier?     @relation(fields: [supplierId], references: [id])
  category        String?
  taxes           ReceiptTax[]
  merchantName    String?       @map("merchant_name")
  merchantNif     String?       @map("merchant_nif")
  documentNumber  String?       @map("document_number")
  documentDate    DateTime?     @map("document_date") @db.Date
  currency        String        @default("EUR")
  subtotalCents   Int?          @map("subtotal_cents")
  taxCents        Int?          @map("tax_cents")
  discountCents   Int?          @map("discount_cents")
  tipCents        Int?          @map("tip_cents")
  totalCents      Int?          @map("total_cents")
  status          ReceiptStatus @default(processing)
  imageStorageKey String        @map("image_storage_key")
  mimeType        String        @map("mime_type")
  fileSize        Int           @map("file_size")
  rawOcrJson      Json?         @map("raw_ocr_json")
  warnings        Json?
  failureReason   String?       @map("failure_reason")
  items           ReceiptItem[]
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("receipts")
}

model ReceiptItem {
  id             String   @id @default(cuid())
  receiptId      String   @map("receipt_id")
  receipt        Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  description    String
  quantity       Decimal  @db.Decimal(10, 3)
  unitPriceCents Int      @map("unit_price_cents")
  totalCents     Int      @map("total_cents")
  category       String?
  confidence     Float?
  position       Int
  suspect        Boolean  @default(false)
  claims         ParticipantItemClaim[]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("receipt_items")
}
